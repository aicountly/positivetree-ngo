JWT_SECRET=change-me-to-a-long-random-string
APP_ENV=production
CORS_ORIGIN=https://aicountly.co.in
# Online donations are processed by https://sispl.org/api (Razorpay merchant
# lives there). This admin API only manages offline donations recorded by staff,
# so no Razorpay credentials are required here.

# Required: self-hosted Gotenberg (Chromium) PDF service.
# Local dev: docker run --rm -p 3000:3000 gotenberg/gotenberg:8
GOTENBERG_BASE_URL=https://pdf.apis.aicountly.com
GOTENBERG_HTML_PATH=/forms/chromium/convert/html
GOTENBERG_HEALTH_PATH=/health
GOTENBERG_TIMEOUT_SECONDS=60
GOTENBERG_CONNECT_TIMEOUT_SECONDS=10
GOTENBERG_VERIFY_SSL=true
GOTENBERG_AUTH_MODE=basic
GOTENBERG_USERNAME=
GOTENBERG_PASSWORD=

# Legacy alias (optional if GOTENBERG_BASE_URL is set):
# GOTENBERG_URL=https://pdf.apis.aicountly.com
